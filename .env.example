# Xtrava deployment configuration — template.
#
# Copy this file to ".env" and fill in your values; serve.py loads ".env" on
# startup, so you set config once in a file instead of typing it each launch.
# ".env" is gitignored — keep your real password out of version control.
# (Anything you set in the actual terminal environment still overrides .env.)

# Login password for the web app. REQUIRED — the server won't start without it.
XTRAVA_PASSWORD=change-me

# Login username. Optional, defaults to "admin".
XTRAVA_USER=admin

# Network bind address. Optional, defaults to 0.0.0.0.
#   0.0.0.0   = reachable from other devices on your LAN
#   127.0.0.1 = this machine only
XTRAVA_HOST=0.0.0.0

# Port to listen on. Optional, defaults to 5000.
XTRAVA_PORT=5000

# --- Strava scraping targets ---
# Which club to scrape. The leaderboard and recent-activity URLs are derived
# from the base host + club id below. All optional; defaults target the current
# club so nothing breaks without these.
STRAVA_BASE_URL=https://www.strava.com
STRAVA_CLUB_ID=2086579

# Advanced: override a full URL outright (otherwise derived from the two above).
# STRAVA_LEADERBOARD_URL=https://www.strava.com/clubs/2086579/leaderboard
# STRAVA_RECENT_ACTIVITY_URL=https://www.strava.com/clubs/2086579/recent_activity
# STRAVA_LOGIN_URL=https://www.strava.com/login
